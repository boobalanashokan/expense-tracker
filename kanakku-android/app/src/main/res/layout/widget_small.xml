<?xml version="1.0" encoding="utf-8"?>
<!-- Small 2×2 widget — monthly total + today + two quick action buttons -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget"
    android:padding="14dp"
    android:gravity="center_horizontal">

    <!-- App name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💰 Kanakku"
            android:textColor="#93c5fd"
            android:textSize="11sp"
            android:textStyle="bold"/>

        <!-- Refresh button -->
        <TextView
            android:id="@+id/wRefreshBtn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="⟳"
            android:textColor="#4a6590"
            android:textSize="15sp"
            android:gravity="center"
            android:background="@drawable/bg_icon_btn"/>
    </LinearLayout>

    <!-- Monthly total -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="THIS MONTH"
        android:textColor="#6b85b0"
        android:textSize="9sp"
        android:letterSpacing="0.1"/>

    <TextView
        android:id="@+id/wMonth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="₹—"
        android:textColor="#f0f4ff"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp"/>

    <!-- Today total -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TODAY"
            android:textColor="#6b85b0"
            android:textSize="9sp"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/wToday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹—"
            android:textColor="#93c5fd"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Add expense -->
        <LinearLayout
            android:id="@+id/wAddBtn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_btn_blue"
            android:padding="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕"
                android:textSize="13sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Add"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Refund -->
        <LinearLayout
            android:id="@+id/wRefundBtn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_btn_green"
            android:padding="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↩"
                android:textColor="#34d399"
                android:textSize="13sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Refund"
                android:textColor="#34d399"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Last updated -->
    <TextView
        android:id="@+id/wUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#2d3f5e"
        android:textSize="8sp"
        android:layout_marginTop="4dp"/>

</LinearLayout>
